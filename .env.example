# ── WealthTrack Backend ─────────────────────────────────────────
# Copy this to .env and fill in secrets.
#   cp .env.example .env
#
# Settings that have safe defaults are optional — only override
# if you need something different.

# ── Security (REQUIRED) ──
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string
DEBUG=True
ACCESS_TOKEN_EXPIRE_DAYS=30

# ── AI Provider (REQUIRED) ──
OPENCODE_GO_API_KEY=sk-...your-key-here

# ── AI Provider (optional — premium model) ──
OPENROUTER_API_KEY=sk-or-...your-key-here

# ── Web Search (optional) ──
# Used by AI Advisor to fetch real-time financial data.
# Get a free API key at: https://brave.com/search/api/
# If left empty, the backend reads from ~/.hermes/.env (Hermes env).
BRAVE_SEARCH_API_KEY=
